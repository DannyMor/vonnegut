# Vonnegut configuration — copy to .env and fill in values
# All variables are prefixed with VONNEGUT_

# Anthropic API key for AI-assisted transformations (optional)
# VONNEGUT_ANTHROPIC_API_KEY=sk-ant-...

# Encryption key for storing connection passwords at rest (auto-generated if omitted)
# VONNEGUT_SECRET_KEY=

# SQLite database path (default: ./vonnegut.db)
# VONNEGUT_DATABASE_URL=sqlite+aiosqlite:///./vonnegut.db

# CORS origins (default: http://localhost:5173)
# VONNEGUT_CORS_ORIGINS=["http://localhost:5173"]

# Migration limits
# VONNEGUT_MIGRATION_ROW_LIMIT=100000
# VONNEGUT_MIGRATION_BATCH_SIZE=1000
